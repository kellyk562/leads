# Server Configuration
PORT=5000
NODE_ENV=development

# Database (SQLite - path will be created automatically)
DATABASE_PATH=./data/leads.db

# Optional: For production on Render, use persistent disk
# DATABASE_PATH=/var/data/leads.db

# Vapi.ai Voice Calling (optional - enables AI calling features)
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
DEFAULT_ZOOM_LINK=https://zoom.us/j/your-meeting-id

# Gmail API OAuth2 (optional - enables email sending)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=

# Zoom API - Server-to-Server OAuth (optional - auto-creates unique meeting links)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
